msgid "Shown on the login page instead of the WordPress logo."
msgstr "Wird auf der Anmeldeseite anstelle des WordPress-Logos angezeigt."

# Theme settings: Fallback OG image (General tab)
msgid "Fallback OG image"
msgstr "Fallback-OG-Bild"

msgid "Used as the social preview image (og:image) when a page or post has no SEO image and no featured image."
msgstr "Wird als Vorschaubild für soziale Medien (og:image) genutzt, wenn eine Seite oder ein Beitrag kein SEO-Bild und kein Beitragsbild hat."

msgid "Best size: 1200 × 630 px."
msgstr "Ideale Größe: 1200 × 630 px."

msgid "Image"
msgstr "Bild"

# Theme settings: Excerpt (General tab)
msgid "Excerpt"
msgstr "Auszug"

msgid "Defines how automatically generated excerpts are shortened."
msgstr "Legt fest, wie automatisch erzeugte Auszüge gekürzt werden."

msgid "Excerpt length"
msgstr "Auszugslänge"

msgid "Number of words used when trimming excerpts."
msgstr "Anzahl der Wörter beim Kürzen von Auszügen."

msgid "Excerpt \"more\" text"
msgstr "Auszug „Weiterlesen“-Text"

msgid "Text shown after the excerpt when it is truncated (e.g. …). Leave blank for none."
msgstr "Text, der nach dem Auszug angezeigt wird, wenn er gekürzt wurde (z. B. …). Leer lassen für keinen."

# SVG upload
msgid "SVG file must be under %1$s. You tried to upload a file of %2$s."
msgstr "Die SVG-Datei muss unter %1$s liegen. Du hast eine Datei mit %2$s hochgeladen."

msgid "SVG file not found."
msgstr "SVG-Datei nicht gefunden."

msgid "Invalid or unsafe SVG file."
msgstr "Ungültige oder unsichere SVG-Datei."

