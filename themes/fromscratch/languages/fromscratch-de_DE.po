msgstr "Legt fest, ob die Standardsprache ebenfalls ein URL-Präfix verwendet."

msgid "Language switcher"
msgstr "Sprachumschalter"

msgid "To display a language switcher in your theme, use the shortcode [fs_language_switcher]."
msgstr "Um einen Sprachumschalter im Theme anzuzeigen, verwende den Shortcode [fs_language_switcher]."

msgid "Language will not be shown in language toggler"
