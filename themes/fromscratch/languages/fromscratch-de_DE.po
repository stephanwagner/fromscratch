msgstr "Geschützter Bereich"

msgid "Access denied"
msgstr "Zugriff verweigert"

msgid "You do not have access to this site."
msgstr "Du hast keinen Zugriff auf diese Website."

# Theme settings: Maintenance mode (Security tab)
msgid "Maintenance mode"
msgstr "Wartungsmodus"

msgid "When enabled, the entire frontend is blocked with HTTP 503."
msgstr "Wenn aktiviert, wird die gesamte Website mit HTTP 503 blockiert."

msgid "Logged-in administrators and editors can still view the site."
msgstr "Eingeloggte Administratoren und Redakteure können die Website weiterhin ansehen."

msgid "Enable maintenance mode"
msgstr "Wartungsmodus aktivieren"

msgid "Maintenance"
msgstr "Wartung"

msgid "Heading shown on the maintenance page. Leave blank for default."
msgstr "Überschrift auf der Wartungsseite. Leer lassen für die Standardüberschrift."

msgid "Short message shown below the title. Leave blank for default."
msgstr "Kurzer Hinweistext unter der Überschrift. Leer lassen für den Standardtext."

msgid "We are currently performing scheduled maintenance. Please check back shortly."
msgstr "Es werden planmäßige Wartungsarbeiten durchgeführt. Bitte in Kürze wieder vorbeischauen."

# Blocked IP addresses & Failed login attempts (Security tab)
msgid "Blocked IP addresses"
msgstr "Blockierte IP-Adressen"

msgid "One IP address per line. Supports single IPs, CIDR ranges, or wildcards."
msgstr "Eine IP-Adresse pro Zeile. Unterstützt einzelne IPs, CIDR-Bereiche oder Wildcards."

msgid "Be careful when blocking IP addresses. Incorrect rules may lock you out of your own site."
msgstr "Vorsicht beim Blockieren von IP-Adressen. Falsche Regeln können dich von deiner eigenen Website aussperren."

msgid "Your current IP address:"
msgstr "Deine aktuelle IP-Adresse:"

msgid "Your current IP address could not be detected."
msgstr "Deine aktuelle IP-Adresse konnte nicht ermittelt werden."

msgid "Failed login attempts"
msgstr "Fehlgeschlagene Anmeldeversuche"

msgid "Shows recent failed login attempts."
msgstr "Zeigt die letzten fehlgeschlagenen Anmeldeversuche."

msgid "IPs exceeding the configured threshold are listed as suspicious and can be blocked."
msgstr "IPs über dem konfigurierten Schwellenwert werden als verdächtig aufgeführt und können blockiert werden."

msgid "No failed login attempts recorded."
msgstr "Keine fehlgeschlagenen Anmeldeversuche aufgezeichnet."

